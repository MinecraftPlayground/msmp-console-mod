{
  "schemaVersion": 1,
  "id": "msmp-console",
  "version": "${version}",
  "name": "MSMP Console",
  "description": "This Minecraft Fabric Mod extends the MSMP (Minecraft Server Management Protocol) to also transmit server console events.",
  "authors": [],
  "contact": {},
  "license": "LGPL-3.0",
  "icon": "assets/msmp-console/icon.png",
  "environment": "server",
  "entrypoints": {
    "fabric-datagen": [
      "dev.loat.msmp_console.client.MSMPConsoleDataGenerator"
    ],
    "main": [
      "dev.loat.msmp_console.MSMPConsole"
    ]
  },
  "mixins": [
    "msmp-console.mixins.json",
    {
      "config": "msmp-console.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "custom": {
    "mc-publish": {
      "modrinth": {
        "project_id": "kVuh4pG0",
        "loaders": [
          "fabric"
        ]
      }
    }
  }
}
